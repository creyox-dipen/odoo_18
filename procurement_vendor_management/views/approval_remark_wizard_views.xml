<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approval_remark_wizard_form" model="ir.ui.view">
        <field name="name">approval.remark.wizard.form</field>
        <field name="model">approval.remark.wizard</field>
        <field name="arch" type="xml">
            <form string="Enter Remark">
                <group>
                    <field name="purchase_id" readonly="1"/>
                    <field name="action" readonly="1"/>
                    <field name="remark" placeholder="Enter comments/reason here..."/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
