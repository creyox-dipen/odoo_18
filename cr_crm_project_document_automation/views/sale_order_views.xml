<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_view_inherited_clickable" model="ir.ui.view">
        <field name="name">sale.order.form.view.inherited.clickable</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="bizzup_crm_customization.sale_order_form_view_inherited"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='quotation_number']" position="replace">
                <field name="quotation_number_link" string="Quotation Number"/>
            </xpath>
            <xpath expr="//field[@name='opportunity_number']" position="replace">
                <field name="opportunity_number_link" string="Opportunity Number"/>
            </xpath>
        </field>
    </record>
</odoo>
