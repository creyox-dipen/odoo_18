<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Warning Wizard View -->
    <record id="view_cr_folder_change_warning_form" model="ir.ui.view">
        <field name="name">cr.folder.change.warning.form</field>
        <field name="model">cr.folder.change.warning</field>
        <field name="arch" type="xml">
            <form string="Warning: Category Change">
                <sheet>
                    <group>
                        <field name="message" widget="char" nolabel="1" colspan="2"
                               style="font-weight: bold; color: #e74c3c;"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Continue" type="object"
                            name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" type="object"
                            name="action_cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
