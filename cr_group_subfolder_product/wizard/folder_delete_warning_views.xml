<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_cr_folder_delete_warning_form" model="ir.ui.view">
        <field name="name">cr.folder.delete.warning.form</field>
        <field name="model">cr.folder.delete.warning</field>
        <field name="arch" type="xml">
            <form string="Folder Deletion Status">
                <sheet>
                    <field name="line_ids" invisible="1"/>
                    <div class="alert alert-warning" role="alert" invisible="not message">
                        <field name="message" readonly="1" nolabel="1"/>
                    </div>
                    <p invisible="message">
                        Are you sure you want to delete the selected empty folders?
                    </p>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Proceed" type="object" class="btn-primary"
                            invisible="not line_ids"/>
                    <button string="Close" class="btn-secondary" special="cancel"
                            invisible="line_ids"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary"
                            invisible="not line_ids"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cr_folder_delete_warning" model="ir.actions.act_window">
        <field name="name">Confirm Folder Deletion</field>
        <field name="res_model">cr.folder.delete.warning</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
