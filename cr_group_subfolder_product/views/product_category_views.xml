<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_category_form_folder_structure" model="ir.ui.view">
        <field name="name">product.category.form.folder.structure</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <!-- Target the 'Inventory Valuation' group by looking for its internal fields -->
            <xpath expr="//group[field[@name='property_cost_method']]" position="after">
                <group string="Folder Structure" name="cr_folder_structure">
                    <div colspan="2">
                        <button name="action_delete_checked_lines" string="Delete Selected"
                                type="object" class="btn-secondary mb-2" icon="fa-trash-o"
                                help="Delete all folder lines that have 'Select' checked."/>
                    </div>
                    <field name="folder_structure_ids" nolabel="1" colspan="2">
                        <list string="Folder Structure" editable="bottom" delete="0">
                            <field name="is_selected" string="Select" widget="boolean" nolabel="1"/>
                            <field name="sequence" string="Sequence" widget="char"
                                   help="Use dot notation: 1.0 = top-level, 1.1 = child of 1.0, 1.1.1 = child of 1.1"/>
                            <field name="name" string="Folder Name"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
