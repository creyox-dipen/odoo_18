<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Inherit Product Template Form to add the "Folders" smart button -->
    <record id="product_template_form_view_inherit_folders" model="ir.ui.view">
        <field name="name">product.template.form.inherit.folders</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- Hide the base Documents smart button -->
            <xpath expr="//button[@name='action_open_documents']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add and rename our folders smart button after Forecasted button -->
            <xpath expr="//button[@name='action_product_tmpl_forecast_report']" position="after">
                <button name="action_view_product_folders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-folder-open">
                    <field name="folder_count" widget="statinfo" string="Documents"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
