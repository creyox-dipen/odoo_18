<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_cr_data_processing_log_tree" model="ir.ui.view">
        <field name="name">cr.data.processing.log.tree</field>
        <field name="model">cr.data.processing.log</field>
        <field name="arch" type="xml">
            <list string="Data Processing Logs" default_order="create_date desc" decoration-success="status == 'success'" decoration-warning="status == 'partial'" decoration-danger="status == 'failure'">
                <field name="initiated_at"/>
                <field name="operation_type"/>
                <field name="table_name"/>
                <field name="record_count"/>
                <field name="success_count"/>
                <field name="partial_count" optional="hide"/>
                <field name="failed_count" optional="hide"/>
                <field name="status" widget="badge" decoration-success="status == 'success'" decoration-warning="status == 'partial'" decoration-danger="status == 'failure'"/>
                <field name="timestamp"/>
                <field name="error_message" optional="hide"/>
                <field name="completed_at" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_cr_data_processing_log_form" model="ir.ui.view">
        <field name="name">cr.data.processing.log.form</field>
        <field name="model">cr.data.processing.log</field>
        <field name="arch" type="xml">
            <form string="Data Processing Log" create="false" edit="false">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="success,partial,failure"/>
                </header>
                <sheet> 
                    
                    <div class="oe_title">
                        <h1>
                            <field name="operation_type" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="table_name" readonly="1"/>
                        </h2>
                    </div>

                    <group name="main_info">
                        <group string="Operation Details">
                            <field name="initiated_at" readonly="1"/>
                            <field name="completed_at" readonly="1"/>
                            <field name="timestamp" readonly="1"/>
                        </group>
                        <group string="Statistics">
                            <field name="record_count" readonly="1"/>
                            <field name="success_count" readonly="1"/>
                            <field name="partial_count" readonly="1" invisible="partial_count == 0"/>
                            <field name="failed_count" readonly="1" invisible="failed_count == 0"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Summary" invisible="not message">
                            <group>
                                <field name="message" readonly="1" nolabel="1" widget="text"/>
                            </group>
                        </page>
                        <page string="Error Summary" invisible="not error_message">
                            <group>
                                <field name="error_message" readonly="1" nolabel="1" widget="text"/>
                            </group>
                        </page>
                        <page string="Detailed Errors" invisible="not detailed_errors">
                            <group>
                                <field name="detailed_errors" readonly="1" nolabel="1" widget="text"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_cr_data_processing_log_search" model="ir.ui.view">
        <field name="name">cr.data.processing.log.search</field>
        <field name="model">cr.data.processing.log</field>
        <field name="arch" type="xml">
            <search string="Search Data Processing Logs">
                <field name="table_name"/>
                <field name="operation_type"/>
                <field name="status"/>
                
                <filter string="Success" name="filter_success" domain="[('status', '=', 'success')]"/>
                <filter string="Partial Success" name="filter_partial" domain="[('status', '=', 'partial')]"/>
                <filter string="Failed" name="filter_failed" domain="[('status', '=', 'failure')]"/>
                
                <separator/>
                <filter string="Sheet to Odoo" name="filter_sheet_to_odoo" domain="[('operation_type', '=', 'sheet_to_odoo')]"/>
                <filter string="Odoo to Sheet" name="filter_odoo_to_sheet" domain="[('operation_type', '=', 'odoo_to_sheet')]"/>
                <filter string="Fetch Models" name="filter_fetch_models" domain="[('operation_type', '=', 'fetch_models_list')]"/>
                <filter string="Fetch Fields" name="filter_fetch_fields" domain="[('operation_type', '=', 'fetch_model_fields')]"/>
                
                <separator/>
                <filter string="Last 7 Days" name="filter_week" domain="[('initiated_at', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last 30 Days" name="filter_month" domain="[('initiated_at', '&gt;=', (context_today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Operation Type" name="group_operation_type" context="{'group_by': 'operation_type'}"/>
                    <filter string="Table Name" name="group_table" context="{'group_by': 'table_name'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'initiated_at:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_cr_data_processing_log" model="ir.actions.act_window">
        <field name="name">Data Processing Logs</field>
        <field name="res_model">cr.data.processing.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No logs found
            </p>
            <p>
                Data processing logs will appear here when you perform operations like:
                <ul>
                    <li>Importing data from Google Sheets to Odoo</li>
                    <li>Exporting data from Odoo to Google Sheets</li>
                    <li>Fetching model lists or field information</li>
                </ul>
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_cr_data_processing_log" 
              name="Data Processing Logs" 
              parent="odoo_to_sheet_connector_menu"
              action="action_cr_data_processing_log" 
              sequence="2"/>
</odoo>
