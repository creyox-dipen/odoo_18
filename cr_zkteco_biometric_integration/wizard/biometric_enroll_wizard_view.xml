<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_biometric_enroll_wizard_form" model="ir.ui.view">
        <field name="name">biometric.enroll.wizard.form</field>
        <field name="model">biometric.enroll.wizard</field>
        <field name="arch" type="xml">
            <form string="Remote Biometric Enrollment">
                <group>
                    <group>
                        <field name="employee_id" readonly="1"/>
                        <field name="enroll_type" widget="radio"/>
                    </group>
                    <group>
                        <field name="device_id" options="{'no_create': True}"/>
                        <field name="finger_index" invisible="enroll_type != 'finger'" required="enroll_type == 'finger'"/>
                    </group>
                </group>
                <footer>
                    <button name="action_start_enrollment" string="Start Enrollment" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_biometric_enroll_wizard" model="ir.actions.act_window">
        <field name="name">Remote Enrollment</field>
        <field name="res_model">biometric.enroll.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
