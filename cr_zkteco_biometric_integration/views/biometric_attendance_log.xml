<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         List View: biometric.attendance.log
    ====================================================================== -->
    <record id="view_biometric_attendance_log_list" model="ir.ui.view">
        <field name="name">biometric.attendance.log.list</field>
        <field name="model">biometric.attendance.log</field>
        <field name="arch" type="xml">
            <list string="Attendance Logs"
                  decoration-success="status == 'processed'"
                  decoration-danger="status == 'failed'"
                  decoration-muted="status == 'new'">
                <field name="device_id"/>
                <field name="device_user_id" string="Device UID"/>
                <field name="employee_id" string="Employee"/>
                <field name="timestamp" string="Punch Time (UTC)"/>
                <field name="verify_state" string="State"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'processed'"
                       decoration-danger="status == 'failed'"
                       decoration-warning="status == 'new'"/>
            </list>
        </field>
    </record>

    <!-- =====================================================================
         Form View: biometric.attendance.log
    ====================================================================== -->
    <record id="view_biometric_attendance_log_form" model="ir.ui.view">
        <field name="name">biometric.attendance.log.form</field>
        <field name="model">biometric.attendance.log</field>
        <field name="arch" type="xml">
            <form string="Attendance Log">
                <header>
                    <button name="action_process_punch" string="Process Punch" type="object" class="oe_highlight" invisible="status == 'processed'" groups="hr_attendance.group_hr_attendance_manager"/>
                    <field name="status" widget="statusbar" statusbar_visible="new,processed,failed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Punch Photo">
                            <field name="image" widget="image" nolabel="1"/>
                        </group>
                        <group string="Punch Details">
                            <field name="device_id"/>
                            <field name="device_user_id"/>
                            <field name="employee_id"/>
                            <field name="timestamp"/>
                            <field name="verify_state"/>
                            <field name="status"/>
                        </group>
                        <group string="Deduplication">
                            <field name="unique_key" readonly="1"/>
                        </group>
                    </group>
                    <group string="Raw ATTLOG Line">
                        <field name="raw_data" nolabel="1"
                               widget="text" readonly="1" style="width: 800px;"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =====================================================================
         Search View: biometric.attendance.log
    ====================================================================== -->
    <record id="view_biometric_attendance_log_search" model="ir.ui.view">
        <field name="name">biometric.attendance.log.search</field>
        <field name="model">biometric.attendance.log</field>
        <field name="arch" type="xml">
            <search string="Search Attendance Logs">
                <field name="device_id" string="Device"/>
                <field name="employee_id" string="Employee"/>
                <field name="device_user_id" string="Device UID"/>

                <filter string="New" name="status_new"
                        domain="[('status', '=', 'new')]"/>
                <filter string="Processed" name="status_processed"
                        domain="[('status', '=', 'processed')]"/>
                <filter string="Failed" name="status_failed"
                        domain="[('status', '=', 'failed')]"/>

                <separator/>
                <filter string="Today" name="today"
                        domain="[('timestamp', '&gt;=', datetime.datetime.now().replace(hour=0,minute=0,second=0).strftime('%Y-%m-%d %H:%M:%S'))]"/>

                <group expand="0" string="Group By">
                    <filter string="Device" name="group_device"
                            context="{'group_by': 'device_id'}"/>
                    <filter string="Employee" name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Status" name="group_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Punch Date" name="group_date"
                            context="{'group_by': 'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- =====================================================================
         Action: biometric.attendance.log
    ====================================================================== -->
    <record id="action_biometric_attendance_log" model="ir.actions.act_window">
        <field name="name">Attendance Logs</field>
        <field name="res_model">biometric.attendance.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_biometric_attendance_log_search"/>
        <field name="context">{'search_default_status_processed': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No attendance logs received yet!
            </p>
            <p>
                Logs appear automatically as your ZKTeco device pushes
                attendance data to <strong>/iclock/cdata</strong>.
            </p>
        </field>
    </record>

</odoo>