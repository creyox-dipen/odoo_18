<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_biometric_inherit" model="ir.ui.view">
        <field name="name">res.users.form.biometric.inherit</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']/group" position="after">
                <group string="Biometric Access">
                    <field name="can_edit_biometric_data" widget="boolean_toggle"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
