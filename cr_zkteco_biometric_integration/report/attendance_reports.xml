<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Actions -->
    <record id="action_report_daily_summary" model="ir.actions.report">
        <field name="name">Daily Summary Report</field>
        <field name="model">biometric.daily.summary.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cr_zkteco_biometric_integration.report_daily_summary_template</field>
        <field name="report_file">cr_zkteco_biometric_integration.report_daily_summary_template</field>
        <field name="binding_model_id" ref="model_biometric_daily_summary_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_absence" model="ir.actions.report">
        <field name="name">Absence Report</field>
        <field name="model">biometric.absence.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cr_zkteco_biometric_integration.report_absence_template</field>
        <field name="report_file">cr_zkteco_biometric_integration.report_absence_template</field>
        <field name="binding_model_id" ref="model_biometric_absence_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_daily_attendance" model="ir.actions.report">
        <field name="name">Daily Attendance Report</field>
        <field name="model">biometric.daily.attendance.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cr_zkteco_biometric_integration.report_daily_attendance_template</field>
        <field name="report_file">cr_zkteco_biometric_integration.report_daily_attendance_template</field>
        <field name="binding_model_id" ref="model_biometric_daily_attendance_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Daily Summary Template -->
    <template id="report_daily_summary_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="data" t-value="o.get_report_data()"/>
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', 'Arial', sans-serif; font-size: 13px;">
                        
                        <div class="text-center" style="margin-bottom: 20px;">
                            <h2 style="color: #6a4a6e; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid #6a4a6e; padding-bottom: 10px;">Daily Attendance Summary</h2>
                        </div>

                        <!-- Top Info Boxes -->
                        <div class="row" style="margin-bottom: 25px;">
                            <div class="col-6">
                                <div style="border: 1px solid #ddd; border-left: 4px solid #6a4a6e; padding: 10px; border-radius: 4px; background-color: #fcfcfc; height: 100%;">
                                    <h5 style="color: #999; font-size: 14px; margin-top: 0;">Report Date</h5>
                                    <p style="margin-bottom: 5px;"><strong>Summary Date:</strong> <t t-esc="data['date']"/></p>
                                    <p style="margin-bottom: 0;"><strong>Day:</strong> <t t-esc="data['day']"/></p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div style="border: 1px solid #ddd; border-left: 4px solid #6a4a6e; padding: 10px; border-radius: 4px; background-color: #fcfcfc; height: 100%;">
                                    <h5 style="color: #999; font-size: 14px; margin-top: 0;">Generation Info</h5>
                                    <p style="margin-bottom: 5px;"><strong>Generated:</strong> <t t-esc="data['generated_on']"/></p>
                                    <p style="margin-bottom: 0;"><strong>Generated By:</strong> <t t-esc="data['generated_by']"/></p>
                                </div>
                            </div>
                        </div>

                        <!-- Attendance Overview -->
                        <h4 style="color: #6a4a6e; margin-bottom: 15px; border-bottom: 1px solid #ddd; padding-bottom: 5px;">Attendance Overview</h4>
                        <table class="table table-bordered text-center" style="margin-bottom: 30px; border-collapse: collapse;">
                            <thead style="background-color: #6a4a6e; color: white;">
                                <tr>
                                    <th style="width: 20%;">Total Employees</th>
                                    <th style="width: 20%;">Present</th>
                                    <th style="width: 20%;">Absent</th>
                                    <th style="width: 20%;">Late Arrivals</th>
                                    <th style="width: 20%;">Early Departures</th>
                                </tr>
                            </thead>
                            <tbody style="font-size: 18px; font-weight: bold;">
                                <tr>
                                    <td style="padding: 15px; color: #6a4a6e;"><t t-esc="data['total_employees']"/></td>
                                    <td style="padding: 15px; color: #28a745;"><t t-esc="data['present_count']"/></td>
                                    <td style="padding: 15px; color: #dc3545;"><t t-esc="data['absent_count']"/></td>
                                    <td style="padding: 15px; color: #ffc107;"><t t-esc="data['late_count']"/></td>
                                    <td style="padding: 15px; color: #17a2b8;"><t t-esc="data['early_count']"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Absent Employees Details -->
                        <h4 style="color: #6a4a6e; margin-bottom: 10px;">Absent Employees <small style="color: #999; font-size: 12px;">(<t t-esc="data['absent_count']"/> employees)</small></h4>
                        <div style="border-top: 1px solid #ddd; padding-top: 10px;">
                            <table class="table table-sm table-bordered">
                                <thead style="background-color: #6a4a6e; color: white;">
                                    <tr class="text-center">
                                        <th style="width: 50px; vertical-align: middle;">Sl.No</th>
                                        <th style="vertical-align: middle;">Employee Name</th>
                                        <th style="vertical-align: middle;">Company/Location</th>
                                        <th style="vertical-align: middle;">Department</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="sl" t-value="1"/>
                                    <t t-foreach="data['absent_employees']" t-as="emp">
                                        <tr class="text-center" style="height: 35px;">
                                            <td style="vertical-align: middle;"><t t-esc="sl"/></td>
                                            <td style="vertical-align: middle;"><strong><t t-esc="emp['name']"/></strong></td>
                                            <td style="color: #666; vertical-align: middle;"><t t-esc="emp['company']"/></td>
                                            <td style="color: #666; vertical-align: middle;"><t t-esc="emp['department']"/></td>
                                        </tr>
                                        <t t-set="sl" t-value="sl + 1"/>
                                    </t>
                                    <t t-if="not data['absent_employees']">
                                        <tr>
                                            <td colspan="4" class="text-center" style="vertical-align: middle;">No absences found for this date.</td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Absence Report Template -->
    <template id="report_absence_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="data" t-value="o.get_report_data()"/>
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', 'Arial', sans-serif; font-size: 13px;">
                        
                        <div class="text-center" style="margin-bottom: 20px;">
                            <h2 style="color: #6a4a6e; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid #6a4a6e; padding-bottom: 10px;">Employee Absence Report</h2>
                        </div>

                        <!-- Summary Boxes -->
                        <div class="row" style="margin-bottom: 30px;">
                            <div class="col-6">
                                <div style="border: 1px solid #ddd; border-left: 4px solid #6a4a6e; padding: 10px; border-radius: 4px; background-color: #fcfcfc; height: 100%;">
                                    <h5 style="color: #999; font-size: 14px; margin-top: 0;">Report Period</h5>
                                    <p style="margin-bottom: 5px;"><strong>Start Date:</strong> <t t-esc="data['from_date']"/></p>
                                    <p style="margin-bottom: 0;"><strong>End Date:</strong> <t t-esc="data['to_date']"/></p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div style="border: 1px solid #ddd; border-left: 4px solid #6a4a6e; padding: 10px; border-radius: 4px; background-color: #fcfcfc; height: 100%;">
                                    <h5 style="color: #999; font-size: 14px; margin-top: 0;">Summary</h5>
                                    <p style="margin-bottom: 5px;"><strong>Total Absences:</strong> <span style="color: #6a4a6e; font-weight: bold;"><t t-esc="data['total_absences']"/></span></p>
                                    <p style="margin-bottom: 0;"><strong>Report Generated:</strong> <t t-esc="data['generated_on']"/></p>
                                </div>
                            </div>
                        </div>

                        <h4 style="color: #6a4a6e; margin-bottom: 10px; border-bottom: 1px solid #ddd; padding-bottom: 5px;">Absence Details</h4>

                        <table class="table table-sm table-bordered" style="width: 100%; border-collapse: collapse;">
                            <thead style="background-color: #6a4a6e; color: white;">
                                <tr class="text-center">
                                    <th style="width: 50px; vertical-align: middle;">Sl.No</th>
                                    <th style="vertical-align: middle;">Employee Name</th>
                                    <th style="vertical-align: middle;">Department</th>
                                    <th style="vertical-align: middle;">Company/Location</th>
                                    <th style="vertical-align: middle;">Absence Date</th>
                                    <th style="vertical-align: middle;">Day</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sl_no" t-value="1"/>
                                <t t-foreach="data['absent_records']" t-as="line">
                                    <tr class="text-center" style="height: 35px;">
                                        <td style="vertical-align: middle;"><t t-esc="sl_no"/></td>
                                        <td style="vertical-align: middle;"><strong><t t-esc="line['employee']"/></strong></td>
                                        <td style="color: #666; vertical-align: middle;"><t t-esc="line['department']"/></td>
                                        <td style="color: #666; vertical-align: middle;"><t t-esc="line['company']"/></td>
                                        <td style="color: #6a4a6e; font-weight: bold; vertical-align: middle;"><t t-esc="line['date']"/></td>
                                        <td style="vertical-align: middle;"><t t-esc="line['day']"/></td>
                                    </tr>
                                    <t t-set="sl_no" t-value="sl_no + 1"/>
                                </t>
                            </tbody>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Daily Attendance Status Template -->
    <template id="report_daily_attendance_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="data" t-value="o.get_report_data()"/>
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica', 'Arial', sans-serif; font-size: 13px;">
                        
                        <div class="text-center" style="margin-bottom: 20px;">
                            <h2 style="color: #6a4a6e; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid #6a4a6e; padding-bottom: 10px;">Daily Attendance Report</h2>
                        </div>

                        <!-- Top Info Boxes -->
                        <div class="row" style="margin-bottom: 25px;">
                            <div class="col-6">
                                <div style="border: 1px solid #ddd; border-left: 4px solid #6a4a6e; padding: 10px; border-radius: 4px; background-color: #fcfcfc; height: 100%;">
                                    <h5 style="color: #999; font-size: 13px; margin-top: 0;">Report Date</h5>
                                    <p style="margin-bottom: 5px;"><strong>Selected Date:</strong> <t t-esc="data['date']"/></p>
                                    <p style="margin-bottom: 0;"><strong>Day:</strong> <t t-esc="data['day']"/></p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div style="border: 1px solid #ddd; border-left: 4px solid #6a4a6e; padding: 10px; border-radius: 4px; background-color: #fcfcfc; height: 100%;">
                                    <h5 style="color: #999; font-size: 13px; margin-top: 0;">Summary</h5>
                                    <p style="margin-bottom: 5px;"><strong>Employees Present:</strong> <span style="color: #28a745; font-weight: bold;"><t t-esc="data['present_count']"/></span></p>
                                    <p style="margin-bottom: 0;"><strong>Report Generated:</strong> <t t-esc="data['generated_on']"/></p>
                                </div>
                            </div>
                        </div>

                        <h4 style="color: #6a4a6e; margin-bottom: 10px;">Attendance Details</h4>

                        <table class="table table-sm table-bordered" style="width: 100%; border-collapse: collapse;">
                            <thead style="background-color: #6a4a6e; color: white;">
                                <tr class="text-center">
                                    <th style="width: 50px; vertical-align: middle;">Sl.No</th>
                                    <th style="vertical-align: middle;">Employee Name</th>
                                    <th style="vertical-align: middle;">Check In</th>
                                    <th style="vertical-align: middle;">Check Out</th>
                                    <th style="vertical-align: middle;">Difference (Hrs)</th>
                                    <th style="vertical-align: middle;">Worked Hours</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sl" t-value="1"/>
                                <t t-foreach="data['lines']" t-as="line">
                                    <tr class="text-center" style="height: 35px;">
                                        <td style="vertical-align: middle;"><t t-esc="sl"/></td>
                                        <td style="vertical-align: middle;"><strong><t t-esc="line['employee']"/></strong></td>
                                        <td style="color: #28a745; font-weight: bold; vertical-align: middle;"><t t-esc="line['check_in']"/></td>
                                        <td style="color: #dc3545; font-weight: bold; vertical-align: middle;"><t t-esc="line['check_out']"/></td>
                                        <td style="color: #17a2b8; vertical-align: middle;"><t t-esc="line['difference']"/></td>
                                        <td style="color: #004085; font-weight: bold; vertical-align: middle;"><t t-esc="line['worked_hours']"/></td>
                                    </tr>
                                    <t t-set="sl" t-value="sl + 1"/>
                                </t>
                                <!-- Footer Totals -->
                                <tr class="text-center" style="background-color: #f8f9fa; font-weight: bold; height: 35px;">
                                    <td colspan="2" style="vertical-align: middle;">TOTALS</td>
                                    <td colspan="2" style="vertical-align: middle;">Employees: <t t-esc="data['present_count']"/></td>
                                    <td colspan="2" style="vertical-align: middle;">
                                        Total Hours: <t t-esc="data['total_hours']"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Bottom Summary -->
                        <div class="row" style="margin-top: 30px; border-top: 1px solid #eee; padding-top: 20px;">
                            <div class="col-6">
                                <h5 style="color: #6a4a6e; border-bottom: 1px solid #ddd; padding-bottom: 5px;">Attendance Statistics</h5>
                                <p style="margin-top: 10px;"><strong>Total Present:</strong> <span style="color: #28a745;"><t t-esc="data['present_count']"/> employees</span></p>
                                <p><strong>Total Hours:</strong> <t t-esc="data['total_hours']"/> hrs</p>
                            </div>
                            <div class="col-6 text-right">
                                <h5 style="color: #6a4a6e; border-bottom: 1px solid #ddd; padding-bottom: 5px;">Report Information</h5>
                                <p style="margin-top: 10px; color: #999;">Generated by: <t t-esc="data['generated_by']"/></p>
                                <p style="color: #999;"><t t-esc="data['company']"/></p>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
