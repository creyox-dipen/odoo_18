<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="moto_payment_button_on_invoice_form_id" model="ir.ui.view">
        <field name="name">moto.payment.button.invoice.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_reverse']" position="after">
                <button
                        string="Take Card Payment"
                        name="open_moto_payment_wizard"
                        type="object"
                        id="stripe_moto_payment_button_id"
                        invisible="((move_type != 'out_invoice') or (state != 'posted' or payment_state == 'paid'))"
                />
            </xpath>
        </field>
    </record>

</odoo>