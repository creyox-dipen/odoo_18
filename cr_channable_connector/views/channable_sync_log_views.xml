<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_channable_sync_log_form" model="ir.ui.view">
            <field name="name">channable.sync.log.form</field>
            <field name="model">channable.sync.log</field>
            <field name="arch" type="xml">
                <form string="Sync Log" edit="0" create="0">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="marketplace_id" readonly="1"/>
                                <field name="status" readonly="1"/>
                                <field name="start_datetime" readonly="1"/>
                                <field name="end_datetime" readonly="1"/>
                            </group>
                            <group>
                                <field name="duration" readonly="1"/>
                                <field name="orders_count" readonly="1"/>
                                <field name="synced_count" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Log Details / Notes" name="notes">
                                <field name="notes" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_channable_sync_log_list" model="ir.ui.view">
            <field name="name">channable.sync.log.list</field>
            <field name="model">channable.sync.log</field>
            <field name="arch" type="xml">
                <list string="Sync Logs" edit="0" create="0">
                    <field name="name"/>
                    <field name="marketplace_id"/>
                    <field name="start_datetime"/>
                    <field name="end_datetime"/>
                    <field name="duration" string="Duration (sec)"/>
                    <field name="orders_count"/>
                    <field name="synced_count"/>
                    <field name="status" widget="badge" 
                           decoration-success="status == 'success'" 
                           decoration-warning="status == 'partial'" 
                           decoration-danger="status == 'failed'"/>
                </list>
            </field>
        </record>

        <record id="view_channable_sync_log_search" model="ir.ui.view">
            <field name="name">channable.sync.log.search</field>
            <field name="model">channable.sync.log</field>
            <field name="arch" type="xml">
                <search string="Search Sync Logs">
                    <field name="name"/>
                    <field name="marketplace_id"/>
                    <filter string="Success" name="success" domain="[('status', '=', 'success')]"/>
                    <filter string="Failed" name="failed" domain="[('status', '=', 'failed')]"/>
                    <filter string="Partial" name="partial" domain="[('status', '=', 'partial')]"/>
                    <group>
                        <filter string="Marketplace" name="group_marketplace" context="{'group_by':'marketplace_id'}"/>
                        <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_channable_sync_log" model="ir.actions.act_window">
            <field name="name">Sync Logs</field>
            <field name="res_model">channable.sync.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_channable_sync_log_search"/>
        </record>
    </data>
</odoo>
