<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_delivery_carrier_form_inherit_channable" model="ir.ui.view">
            <field name="name">delivery.carrier.form.inherit.channable</field>
            <field name="model">delivery.carrier</field>
            <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Channable" name="channable_carrier_info">
                        <group>
                            <field name="channable_transporter_code"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
