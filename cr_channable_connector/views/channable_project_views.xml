<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_channable_project_form" model="ir.ui.view">
            <field name="name">channable.project.form</field>
            <field name="model">channable.project</field>
            <field name="arch" type="xml">
                <form string="Channable Project">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="channable_identifier"/>
                            <field name="connection_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_channable_project_list" model="ir.ui.view">
            <field name="name">channable.project.list</field>
            <field name="model">channable.project</field>
            <field name="arch" type="xml">
                <list string="Channable Projects">
                    <field name="name"/>
                    <field name="channable_identifier"/>
                    <field name="connection_id"/>
                </list>
            </field>
        </record>

        <record id="action_channable_project" model="ir.actions.act_window">
            <field name="name">Projects</field>
            <field name="res_model">channable.project</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
