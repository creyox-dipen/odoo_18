<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_channable_sync_error_form" model="ir.ui.view">
            <field name="name">channable.sync.error.form</field>
            <field name="model">channable.sync.error</field>
            <field name="arch" type="xml">
                <form string="Sync Error">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="reference" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Error Info">
                                <field name="name" readonly="1"/>
                                <field name="action_attempted" readonly="1"/>
                                <field name="moment" readonly="1"/>
                                <field name="user_id" readonly="1"/>
                            </group>
                            <group string="Related Records">
                                <field name="order_id"
                                       readonly="1"
                                       invisible="not order_id"/>
                                <field name="marketplace_id"
                                       readonly="1"
                                       invisible="not marketplace_id"/>
                            </group>
                        </group>
                        <group string="Detailed Description" groups="base.group_no_one">
                            <field name="detailed_description" nolabel="1" readonly="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_channable_sync_error_list" model="ir.ui.view">
            <field name="name">channable.sync.error.list</field>
            <field name="model">channable.sync.error</field>
            <field name="arch" type="xml">
                <list string="Sync Errors" default_order="moment desc">
                    <field name="reference"/>
                    <field name="name"/>
                    <field name="action_attempted"/>
                    <field name="order_id" optional="show"/>
                    <field name="marketplace_id" optional="show"/>
                    <field name="moment"/>
                    <field name="user_id" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="action_channable_sync_error" model="ir.actions.act_window">
            <field name="name">Sync Errors</field>
            <field name="res_model">channable.sync.error</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
