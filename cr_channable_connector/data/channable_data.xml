<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Sequence for sync error reference ───────────────────────────── -->
        <record id="seq_channable_sync_error" model="ir.sequence">
            <field name="name">Channable Sync Error</field>
            <field name="code">channable.sync.error</field>
            <field name="prefix">CHN-ERR-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- ── Cron: import orders for all active marketplaces ─────────────── -->
        <record id="ir_cron_channable_sync_orders" model="ir.cron">
            <field name="name">Channable: Import Orders</field>
            <field name="model_id" ref="model_channable_marketplace"/>
            <field name="state">code</field>
            <field name="code">model.action_sync_orders_cron()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <!-- <field name="numbercall">-1</field> -->
            <field name="active">True</field>
        </record>

