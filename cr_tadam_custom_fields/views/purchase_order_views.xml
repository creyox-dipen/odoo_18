<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_tadam" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.tadam</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id'][1]" position="after">
                <field name="x_tadam_payout_id"/>
                <field name="x_tadam_booking_id"/>
                <field name="x_payout_status"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="after">
                <field name="x_line_category"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_tree_inherit_tadam" model="ir.ui.view">
        <field name="name">purchase.order.list.inherit.tadam</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="x_tadam_payout_id" optional="show"/>
                <field name="x_tadam_booking_id" optional="show"/>
                <field name="x_payout_status" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_kpis_tree_inherit_tadam" model="ir.ui.view">
        <field name="name">purchase.order.inherit.purchase.order.list.inherit.tadam</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="x_tadam_payout_id" optional="show"/>
                <field name="x_tadam_booking_id" optional="show"/>
                <field name="x_payout_status" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_view_tree_inherit_tadam" model="ir.ui.view">
        <field name="name">purchase.order.view.list.inherit.tadam</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="x_tadam_payout_id" optional="show"/>
                <field name="x_tadam_booking_id" optional="show"/>
                <field name="x_payout_status" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_line_tree_inherit_tadam" model="ir.ui.view">
        <field name="name">purchase.order.line.list.inherit.tadam</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="x_line_category" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>

