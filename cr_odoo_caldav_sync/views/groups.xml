<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="module_category_caldav" model="ir.module.category">
            <field name="name">CalDAV Sync</field>
            <field name="sequence">100</field>
        </record>

        <record id="group_caldav_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_caldav"/>
        </record>

        <record id="group_caldav_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_id" ref="module_category_caldav"/>
            <field name="implied_ids" eval="[(4, ref('group_caldav_user'))]"/>
        </record>

        <!-- User: can only see caldav accounts where they are the owner -->
        <record id="rule_caldav_account_user" model="ir.rule">
            <field name="name">CalDAV Account: User sees own accounts only</field>
            <field name="model_id" ref="model_caldav_account"/>
            <field name="groups" eval="[(4, ref('group_caldav_user'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Admin: can see all caldav accounts -->
        <record id="rule_caldav_account_admin" model="ir.rule">
            <field name="name">CalDAV Account: Admin sees all accounts</field>
            <field name="model_id" ref="model_caldav_account"/>
            <field name="groups" eval="[(4, ref('group_caldav_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>