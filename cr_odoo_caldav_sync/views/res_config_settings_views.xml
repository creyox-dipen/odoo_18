<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Inherit res.config.settings — add CalDAV section
         Uses Odoo 18's <app>/<block>/<setting> structure
    ============================================================ -->
    <record id="res_config_settings_view_form_caldav" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.caldav</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="CalDAV Sync"
                     name="cr_odoo_caldav_sync"
                     logo="/cr_odoo_caldav_sync/static/description/banner.png">

                    <block title="CalDAV Calendar Synchronisation" name="caldav_sync_block">

                        <setting id="caldav_sync_enabled_setting"
                                 string="Enable CalDAV Sync"
                                 help="Automatically sync calendar events with your CalDAV server every 15 minutes.">
                            <field name="caldav_sync_enabled"/>
                            <div class="content-group" invisible="not caldav_sync_enabled">
                                <div class="mt8">
                                    <button name="action_open_caldav_accounts"
                                            string="Manage CalDAV Accounts"
                                            type="object"
                                            icon="oi-arrow-right"
                                            class="btn-link"/>
                                </div>
                            </div>
                        </setting>

                        <setting id="caldav_google_oauth_setting"
                                 string="Google OAuth 2.0 Credentials"
                                 help="Client ID and Secret for Google Calendar API."
                                 invisible="not caldav_sync_enabled">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="caldav_google_client_id" class="col-lg-3 o_light_label"/>
                                    <field name="caldav_google_client_id" class="col-lg-9"/>
                                </div>
                                <div class="row">
                                    <label for="caldav_google_client_secret" class="col-lg-3 o_light_label"/>
                                    <field name="caldav_google_client_secret" password="True" class="col-lg-9"/>
                                </div>
                                <div class="text-muted mt8">
                                    Authorized Redirect URI: <code class="bg-light">/caldav/google/callback</code>
                                </div>
                            </div>
                        </setting>

                    </block>

                </app>
            </xpath>
        </field>
    </record>

</odoo>
